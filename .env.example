# 管理员账号（首次启动时若用户表为空，会用此账号创建初始管理员）
ADMIN_USERNAME=admin

# 管理员密码（留空则首次启动时随机生成，并打印在后端日志中）
ADMIN_PASSWORD=admin

# JWT 密钥（留空则随机生成）
JWT_SECRET=your-secret-key

# 监听地址，留空表示监听所有网卡（0.0.0.0）
# 生产环境配合 1Panel Nginx 反代时可设为 127.0.0.1，避免直接暴露
HOST=

# 代理入口监听端口
PORT=8080

# 管理后台 API 监听端口
ADMIN_PORT=8081

# 启动模式：api（仅启动 API 和代理入口） / all（额外在 admin 端口挂载前端静态页面）
MODE=all

# 前端静态资源目录，MODE=all 时生效
WEB_DIST=web/dist

# PostgreSQL DSN（docker-compose 中已配置，通常无需修改）
DATABASE_URL=postgres://safegate:safegate@postgres:5432/safegate?sslmode=disable

# Redis 地址
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
